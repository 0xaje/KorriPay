# ──────────────────────────────────────────────────────────────────────────────
# KorriPay Environment Variables Template
# ──────────────────────────────────────────────────────────────────────────────

# Node Environment (development, staging, production)
NODE_ENV=production

# Server Port
PORT=5000

# Database URL for Postgres & Prisma client connection
DATABASE_URL="postgresql://postgres:password@localhost:5432/korripay?schema=public&connection_limit=100"

# CORS Whitelist (comma-separated origins)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5000,http://localhost:5173"

# GIWA L2 Node Connectivity
GIWA_RPC_URL="https://rpc.giwa.network"
GIWA_EXPLORER_URL="https://explorer.giwa.network"
GIWA_BRIDGE_URL="https://bridge.giwa.network"

# Trust Provider Settings (mock, dojang, enterprise)
TRUST_PROVIDER=mock
DASHBOARD_LIMIT=2000
DAILY_SETTLEMENT_LIMIT=5000
