// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(uuid())
  name             String           @default("Jane Doe")
  email            String?          @unique
  walletAddress    String?          @unique
  createdAt        DateTime         @default(now())
  wallet           Wallet?
  kycs             Kyc[]
  transactions     Transaction[]
  contacts         Contact[]
  merchantRequests PaymentRequest[] @relation("MerchantRequests")

  @@map("users")
}

model Wallet {
  id       String @id @default(uuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── USD balances ──────────────────────────────────────────────────
  usdAvailable  Float @default(1250.00)
  usdLocked     Float @default(0.00)
  usdPending    Float @default(0.00)

  // ── KRW balances ──────────────────────────────────────────────────
  krwAvailable  Float @default(0.00)
  krwLocked     Float @default(0.00)
  krwPending    Float @default(0.00)

  // ── NGN balances ──────────────────────────────────────────────────
  ngnAvailable  Float @default(0.00)
  ngnLocked     Float @default(0.00)
  ngnPending    Float @default(0.00)

  // ── MockKRW (on-chain stablecoin) balances ─────────────────────────
  mockkrwAvailable  Float @default(500000.00)
  mockkrwLocked     Float @default(0.00)
  mockkrwPending    Float @default(0.00)

  // ── Legacy crypto balances (on-chain, read from blockchain) ────────
  btcBalance    Float @default(14.82)
  ethBalance    Float @default(2.45)
  usdcBalance   Float @default(2450.00)

  // ── Meta ───────────────────────────────────────────────────────────
  savings       Float    @default(45.00)
  updatedAt     DateTime @default(now()) @updatedAt

  ledgerEntries WalletLedger[]

  @@map("wallets")
}

// ── Wallet Ledger: immutable double-entry style audit trail ────────────────
model WalletLedger {
  id          String   @id @default(uuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  // Which currency and balance slot changed
  currency    String   // USD | KRW | NGN | MockKRW | BTC | ETH | USDC
  balanceType String   // available | locked | pending

  // Double-entry: debit is negative, credit is positive
  amount      Float
  runningBalance Float  // snapshot of available balance after this entry

  // Context
  entryType   String   // credit | debit | lock | unlock | settle | refund | fee
  description String
  txHash      String?
  referenceId String?  // settlement ID, fx conversion ID, etc.
  createdAt   DateTime @default(now())

  @@index([walletId, currency])
  @@index([createdAt])
  @@map("wallet_ledger")
}

model Transaction {
  id        String   @id
  title     String
  type      String
  amount    Float
  date      String
  timestamp Float
  category  String
  txHash    String?
  status    String   @default("Success")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Kyc {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("NotStarted")
  updatedAt DateTime @updatedAt

  @@map("kyc")
}

model Settlement {
  id               String    @id
  initiator        String
  fromToken        String
  toToken          String
  amount           String
  recipientDetails String
  status           String    @default("Pending")
  txHash           String?
  confirmedTxHash  String?
  createdAt        DateTime  @default(now())
  confirmedAt      DateTime?

  @@map("settlements")
}

model Contact {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress    String
  name             String
  nickname         String?
  isFavorite       Boolean  @default(false)
  lastTransactedAt DateTime?
  createdAt        DateTime @default(now())

  @@unique([userId, walletAddress])
  @@map("contacts")
}

model PaymentRequest {
  id            String   @id @default(uuid())
  merchantId    String
  merchant      User     @relation("MerchantRequests", fields: [merchantId], references: [id], onDelete: Cascade)
  amount        Float
  currency      String
  description   String
  status        String   @default("Pending") // Pending, Paid, Expired
  createdAt     DateTime @default(now())
  paidAt        DateTime?
  payerAddress  String?
  txHash        String?

  settlements   MerchantSettlement[]

  @@map("payment_requests")
}

model MerchantSettlement {
  id               String         @id @default(uuid())
  paymentRequestId String
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Cascade)
  merchantId       String
  amount           Float
  currency         String
  status           String         @default("Settled") // Settled, Processing, Failed
  txHash           String?
  createdAt        DateTime       @default(now())

  @@map("merchant_settlements")
}

model FxConversion {
  id             String   @id @default(uuid())
  userId         String
  fromCurrency   String   // KRW | USD | NGN
  toAsset        String   // MockKRW | USDC
  inputAmount    Float
  outputAmount   Float
  exchangeRate   Float
  feeUSD         Float    @default(0)
  feeInOutput    Float    @default(0)
  usdEquivalent  Float
  rateSource     String   @default("live") // live | fallback
  txHash         String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("fx_conversions")
}
