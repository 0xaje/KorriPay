generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  name              String             @default("Jane Doe")
  email             String?            @unique
  createdAt         DateTime           @default(now())
  walletAddress     String?            @unique
  role              String             @default("USER")
  suspended         Boolean            @default(false)
  complianceProfile ComplianceProfile?
  contacts          Contact[]
  kycs              Kyc[]
  merchantRequests  PaymentRequest[]   @relation("MerchantRequests")
  transactions      Transaction[]
  wallet            Wallet?
  orgMembers        OrgMember[]

  @@map("users")
}

model Wallet {
  id               String         @id @default(uuid())
  userId           String         @unique
  savings          Float          @default(45.00)
  btcBalance       Float          @default(14.82)
  ethBalance       Float          @default(2.45)
  usdcBalance      Float          @default(2450.00)
  krwAvailable     Float          @default(0.00)
  krwLocked        Float          @default(0.00)
  krwPending       Float          @default(0.00)
  mockkrwAvailable Float          @default(500000.00)
  mockkrwLocked    Float          @default(0.00)
  mockkrwPending   Float          @default(0.00)
  ngnAvailable     Float          @default(0.00)
  ngnLocked        Float          @default(0.00)
  ngnPending       Float          @default(0.00)
  updatedAt        DateTime       @default(now()) @updatedAt
  usdAvailable     Float          @default(1250.00)
  usdLocked        Float          @default(0.00)
  usdPending       Float          @default(0.00)
  ledgerEntries    WalletLedger[]
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model WalletLedger {
  id             String   @id @default(uuid())
  walletId       String
  currency       String
  balanceType    String
  amount         Float
  runningBalance Float
  entryType      String
  description    String
  txHash         String?
  referenceId    String?
  createdAt      DateTime @default(now())
  wallet         Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, currency])
  @@index([createdAt])
  @@map("wallet_ledger")
}

model Transaction {
  id        String  @id
  title     String
  type      String
  amount    Float
  date      String
  timestamp Float
  category  String
  txHash    String?
  status    String  @default("Success")
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Kyc {
  id        String   @id @default(uuid())
  userId    String
  status    String   @default("NotStarted")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc")
}

model Settlement {
  id               String    @id
  initiator        String
  fromToken        String
  toToken          String
  amount           String
  recipientDetails String
  status           String    @default("Pending")
  txHash           String?
  confirmedTxHash  String?
  createdAt        DateTime  @default(now())
  confirmedAt      DateTime?
  pipelineHistory  String    @default("[]")
  pipelineStage    String    @default("Settlement Requested")

  @@map("settlements")
}

model SettlementProof {
  id                 String   @id @default(uuid())
  settlementId       String   @unique
  txHash             String
  blockNumber        Int
  timestamp          DateTime
  gasUsed            String
  settlementDuration Int
  proofStatus        String   @default("Valid")

  @@map("settlement_proofs")
}

model Contact {
  id               String    @id @default(uuid())
  userId           String
  walletAddress    String
  name             String
  nickname         String?
  isFavorite       Boolean   @default(false)
  lastTransactedAt DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, walletAddress])
  @@map("contacts")
}

model PaymentRequest {
  id           String               @id @default(uuid())
  merchantId   String
  amount       Float
  currency     String
  description  String
  status       String               @default("Pending")
  createdAt    DateTime             @default(now())
  paidAt       DateTime?
  payerAddress String?
  txHash       String?
  settlements  MerchantSettlement[]
  merchant     User                 @relation("MerchantRequests", fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("payment_requests")
}

model MerchantSettlement {
  id               String         @id @default(uuid())
  paymentRequestId String
  merchantId       String
  amount           Float
  currency         String
  status           String         @default("Settled")
  txHash           String?
  createdAt        DateTime       @default(now())
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Cascade)

  @@map("merchant_settlements")
}

model FxConversion {
  id            String   @id @default(uuid())
  userId        String
  fromCurrency  String
  toAsset       String
  inputAmount   Float
  outputAmount  Float
  exchangeRate  Float
  feeUSD        Float    @default(0)
  feeInOutput   Float    @default(0)
  usdEquivalent Float
  rateSource    String   @default("live")
  txHash        String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("fx_conversions")
}

model ComplianceProfile {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  riskLevel              String   @default("Low")
  kycEnforced            Boolean  @default(true)
  dailyLimitUSD          Float    @default(5000.00)
  singleTxLimitUSD       Float    @default(2000.00)
  suspiciousThresholdUSD Float    @default(1000.00)
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("compliance_profiles")
}

model ComplianceRule {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  description     String
  isActive        Boolean  @default(true)
  value           Float?
  riskLevelImpact String   @default("Medium")
  updatedAt       DateTime @updatedAt

  @@map("compliance_rules")
}

model ComplianceLog {
  id             String   @id @default(uuid())
  transactionId  String?
  userId         String
  amount         Float
  currency       String
  riskScore      Float    @default(0)
  riskLevel      String   @default("Low")
  result         String
  rulesTriggered String
  details        String
  createdAt      DateTime @default(now())

  @@map("compliance_logs")
}

model ComplianceReport {
  id                String   @id @default(uuid())
  name              String
  type              String
  startPeriod       DateTime
  endPeriod         DateTime
  totalTransactions Int
  flaggedCount      Int
  blockedCount      Int
  summaryData       String
  generatedBy       String   @default("System")
  createdAt         DateTime @default(now())

  @@map("compliance_reports")
}

model Attestation {
  id            String   @id @default(uuid())
  issuer        String
  subjectWallet String
  schema        String
  status        String   @default("Active")
  timestamp     DateTime @default(now())
  details       String?

  @@map("attestations")
}

model AdminAuditLog {
  id        String   @id @default(uuid())
  adminId   String
  adminName String
  action    String
  target    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("admin_audit_logs")
}

model TrustScoreHistory {
  id        String   @id @default(uuid())
  wallet    String
  score     Int
  timestamp DateTime @default(now())

  @@map("trust_score_history")
}

model WebhookSubscription {
  id        String   @id @default(uuid())
  url       String
  events    String   // comma-separated list of subscribed events
  secret    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("webhook_subscriptions")
}

model WebhookDeliveryLog {
  id             String   @id @default(uuid())
  subscriptionId String
  event          String
  payload        String
  responseStatus Int?
  responseBody   String?
  attempts       Int      @default(1)
  success        Boolean
  timestamp      DateTime @default(now())

  @@map("webhook_delivery_logs")
}

model Organization {
  id               String            @id @default(uuid())
  name             String
  taxId            String?
  status           String            @default("Pending")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  members          OrgMember[]
  wallets          OrgWallet[]
  approvalRequests ApprovalRequest[]
  auditLogs        OrgAuditLog[]

  @@map("organizations")
}

model OrgMember {
  id                  String       @id @default(uuid())
  orgId               String
  userId              String
  role                String       // OWNER, ADMIN, FINANCE, DEVELOPER, AUDITOR
  dailySettlementLimit Float        @default(10000.00)
  createdAt           DateTime     @default(now())
  organization        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

model OrgWallet {
  id           String       @id @default(uuid())
  orgId        String
  currency     String
  available    Float        @default(0.00)
  locked       Float        @default(0.00)
  pending      Float        @default(0.00)
  address      String       @unique
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, currency])
  @@map("org_wallets")
}

model ApprovalRequest {
  id           String       @id @default(uuid())
  orgId        String
  initiatorId  String
  type         String       // "SETTLEMENT"
  amount       Float
  currency     String
  payload      String       // JSON string of request details
  status       String       @default("PENDING") // PENDING, APPROVED, REJECTED
  approverId   String?
  createdAt    DateTime     @default(now())
  decidedAt    DateTime?
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("approval_requests")
}

model OrgAuditLog {
  id           String       @id @default(uuid())
  orgId        String
  actorId      String
  action       String
  details      String
  timestamp    DateTime     @default(now())
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_audit_logs")
}

model NetworkSnapshot {
  id              String   @id @default(uuid())
  timestamp       DateTime @default(now())
  chainName       String
  chainId         Int
  rpcUrl          String
  blockNumber     Int
  finalizedBlock  Int
  avgBlockTime    Float
  gasPrice        Float
  sequencerStatus String
  rpcLatency      Int
  explorerStatus  String
  bridgeStatus    String
  healthScore     Int

  @@map("network_snapshots")
}

