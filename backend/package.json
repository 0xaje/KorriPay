    "express": "^4.21.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "prisma": "^6.19.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2"
  }
