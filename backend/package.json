{
  "name": "korripay-backend",
  "version": "1.0.0",
  "description": "Backend server for KorriPay fintech application",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "indexer": "node indexer.js",
    "test": "PORT=0 mocha test/**/*.test.js --timeout 20000 --exit",
