datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  actorId   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
