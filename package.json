{
  "name": "korripay-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade financial infrastructure and settlement engine",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,sol}\"",
